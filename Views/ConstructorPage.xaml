<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:PizzeriaApp.Models"
             x:Class="PizzeriaApp.Views.ConstructorPage"
             Title="Конструктор пиццы">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15">
            <!-- Выбор размера -->
            <Frame BackgroundColor="White" 
                   CornerRadius="12" 
                   Padding="15"
                   HasShadow="False"
                   BorderColor="#E0E0E0">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Размер пиццы" 
                           FontSize="16" 
                           FontAttributes="Bold"
                           TextColor="#333"/>

                    <Picker Title="Выберите размер"
                            ItemsSource="{Binding Sizes}"
                            SelectedItem="{Binding SelectedSize}"
                            ItemDisplayBinding="{Binding Size}"
                            FontSize="16"/>
                </VerticalStackLayout>
            </Frame>

            <!-- Выбор ингредиентов -->
            <Frame BackgroundColor="White" 
                   CornerRadius="12" 
                   Padding="15"
                   HasShadow="False"
                   BorderColor="#E0E0E0">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Дополнительные ингредиенты" 
                           FontSize="16" 
                           FontAttributes="Bold"
                           TextColor="#333"/>

                    <CollectionView ItemsSource="{Binding Ingredients}"
                                    SelectionMode="None">
                        <CollectionView.ItemsLayout>
                            <LinearItemsLayout Orientation="Vertical" ItemSpacing="8"/>
                        </CollectionView.ItemsLayout>

                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:Ingredient">
                                <Grid ColumnDefinitions="Auto,*,Auto" Padding="0,5">
                                    <CheckBox IsChecked="{Binding IsSelected}" 
                                              Color="#FF5722"
                                              VerticalOptions="Center"/>

                                    <Label Grid.Column="1" 
                                           Text="{Binding Name}" 
                                           FontSize="14"
                                           TextColor="#333"
                                           VerticalOptions="Center"
                                           Margin="10,0"/>

                                    <Label Grid.Column="2" 
                                           FontSize="14"
                                           TextColor="#D32F2F"
                                           VerticalOptions="Center">
                                        <Label.FormattedText>
                                            <FormattedString>
                                                <Span Text="+"/>
                                                <Span Text="{Binding Price, StringFormat='{0:N0}'}"/>
                                                <Span Text=" ₽"/>
                                            </FormattedString>
                                        </Label.FormattedText>
                                    </Label>
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </Frame>

            <!-- Количество и цена -->
            <Frame BackgroundColor="White" 
                   CornerRadius="12" 
                   Padding="15"
                   HasShadow="False"
                   BorderColor="#E0E0E0">
                <VerticalStackLayout Spacing="15">

                    <!-- Текущая цена за единицу -->
                    <Grid ColumnDefinitions="Auto,*">
                        <Label Text="Цена за шт:" 
                               FontSize="14"
                               TextColor="#666"
                               VerticalOptions="Center"/>

                        <Label Grid.Column="1" 
                               HorizontalOptions="End"
                               FontSize="18" 
                               FontAttributes="Bold"
                               TextColor="#D32F2F"
                               VerticalOptions="Center">
                            <Label.FormattedText>
                                <FormattedString>
                                    <Span Text="{Binding UnitPrice, StringFormat='{0:N0}'}"/>
                                    <Span Text=" ₽"/>
                                </FormattedString>
                            </Label.FormattedText>
                        </Label>
                    </Grid>

                    <!-- Количество -->
                    <Grid ColumnDefinitions="Auto,*,Auto">
                        <Label Text="Количество:" 
                               FontSize="14"
                               TextColor="#666"
                               VerticalOptions="Center"/>

                        <Stepper Grid.Column="2" 
                                 Value="{Binding Quantity}"
                                 Minimum="1"
                                 Maximum="10"
                                 Increment="1"
                                 HorizontalOptions="End"/>

                        <Label Grid.Column="1" 
                               Text="{Binding Quantity}" 
                               FontSize="16"
                               FontAttributes="Bold"
                               TextColor="#333"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"/>
                    </Grid>

                    <!-- Итоговая цена -->
                    <Grid ColumnDefinitions="Auto,*">
                        <Label Text="Итого:" 
                               FontSize="16"
                               FontAttributes="Bold"
                               TextColor="#333"
                               VerticalOptions="Center"/>

                        <Label Grid.Column="1" 
                               HorizontalOptions="End"
                               FontSize="22" 
                               FontAttributes="Bold"
                               TextColor="#D32F2F"
                               VerticalOptions="Center">
                            <Label.FormattedText>
                                <FormattedString>
                                    <Span Text="{Binding TotalPrice, StringFormat='{0:N0}'}"/>
                                    <Span Text=" ₽"/>
                                </FormattedString>
                            </Label.FormattedText>
                        </Label>
                    </Grid>
                </VerticalStackLayout>
            </Frame>

            <!-- Кнопка добавления в корзину -->
            <Button Text="Добавить в корзину"
                    BackgroundColor="#FF5722"
                    TextColor="White"
                    FontAttributes="Bold"
                    FontSize="16"
                    CornerRadius="12"
                    HeightRequest="50"
                    Command="{Binding AddToCartCommand}"
                    Margin="0,10,0,0"/>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>