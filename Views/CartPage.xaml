<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:PizzeriaApp.Models"
             xmlns:viewmodels="clr-namespace:PizzeriaApp.ViewModels"
             xmlns:converters="clr-namespace:PizzeriaApp.Converters"
             x:Class="PizzeriaApp.Views.CartPage"
             Title="Мой заказ">

    <Grid RowDefinitions="*,Auto" Padding="15">

        <!-- Список товаров в корзине -->
        <CollectionView Grid.Row="0"
                        ItemsSource="{Binding CartItems}"
                        SelectionMode="None"
                        VerticalOptions="FillAndExpand">

            <CollectionView.ItemsLayout>
                <LinearItemsLayout Orientation="Vertical" ItemSpacing="10"/>
            </CollectionView.ItemsLayout>

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:CartItem">
                    <SwipeView>
                        <SwipeView.RightItems>
                            <SwipeItem Text="Удалить"
                                       BackgroundColor="#D32F2F"
                                       Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:CartViewModel}}, Path=DeleteItemCommand}"
                                       CommandParameter="{Binding .}"/>
                        </SwipeView.RightItems>

                        <Frame BackgroundColor="White" 
                               CornerRadius="12" 
                               Padding="12"
                               HasShadow="True"
                               BorderColor="#E0E0E0">

                            <Grid RowDefinitions="Auto,Auto,Auto,Auto" ColumnDefinitions="*,Auto">

                                <!-- Название пиццы -->
                                <Label Grid.Row="0" Grid.Column="0"
                                       Text="{Binding Pizza.Name}" 
                                       FontSize="18" 
                                       FontAttributes="Bold"
                                       TextColor="#333"
                                       Margin="0,0,0,5"/>

                                <!-- Кнопка удаления (альтернатива свайпу) -->
                                <Button Grid.Row="0" Grid.Column="1"
                                        Text="🗑"
                                        BackgroundColor="Transparent"
                                        TextColor="#D32F2F"
                                        FontSize="20"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:CartViewModel}}, Path=DeleteItemCommand}"
                                        CommandParameter="{Binding .}"/>

                                <!-- Размер -->
                                <Label Grid.Row="1" Grid.Column="0"
                                       Text="{Binding Size.Size, StringFormat='Размер: {0}'}" 
                                       FontSize="14"
                                       TextColor="#666"
                                       Margin="0,0,0,5"/>

                                <!-- Ингредиенты -->
                                <Label Grid.Row="2" Grid.Column="0"
                                       FontSize="14"
                                       TextColor="#666"
                                       Margin="0,0,0,10"
                                       IsVisible="{Binding SelectedIngredients, Converter={StaticResource ListToBoolConverter}}">
                                    <Label.FormattedText>
                                        <FormattedString>
                                            <Span Text="Доп: "/>
                                            <Span Text="{Binding SelectedIngredients, Converter={StaticResource IngredientsToStringConverter}}"/>
                                        </FormattedString>
                                    </Label.FormattedText>
                                </Label>

                                <!-- Количество и цена -->
                                <Grid Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2" ColumnDefinitions="Auto,*,Auto,Auto">

                                    <Label Text="Кол-во:" 
                                           FontSize="14"
                                           TextColor="#666"
                                           VerticalOptions="Center"/>

                                    <Stepper Grid.Column="2" 
                                             Value="{Binding Quantity}"
                                             Minimum="1"
                                             Maximum="10"
                                             Increment="1"
                                             HorizontalOptions="Start"
                                             Margin="10,0"/>

                                    <Label Grid.Column="1" 
                                           Text="{Binding Quantity}" 
                                           FontSize="14"
                                           FontAttributes="Bold"
                                           TextColor="#333"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center"/>

                                    <Label Grid.Column="3" 
                                           FontSize="16" 
                                           FontAttributes="Bold"
                                           TextColor="#D32F2F"
                                           VerticalOptions="Center"
                                           HorizontalOptions="End">
                                        <Label.FormattedText>
                                            <FormattedString>
                                                <Span Text="{Binding TotalPrice, StringFormat='{0:N0}'}"/>
                                                <Span Text=" ₽"/>
                                            </FormattedString>
                                        </Label.FormattedText>
                                    </Label>
                                </Grid>
                            </Grid>
                        </Frame>
                    </SwipeView>
                </DataTemplate>
            </CollectionView.ItemTemplate>

            <!-- Пустая корзина -->
            <CollectionView.EmptyView>
                <VerticalStackLayout Padding="20" Spacing="15">
                    <Label Text="🛒" 
                           FontSize="64" 
                           HorizontalOptions="Center"/>
                    <Label Text="Ваша корзина пуста" 
                           FontSize="18" 
                           FontAttributes="Bold"
                           TextColor="#666"
                           HorizontalOptions="Center"/>
                    <Label Text="Добавьте пиццу из меню" 
                           FontSize="14"
                           TextColor="#999"
                           HorizontalOptions="Center"/>

                    <Button Text="Перейти в меню"
                            BackgroundColor="#FF5722"
                            TextColor="White"
                            FontAttributes="Bold"
                            CornerRadius="12"
                            HeightRequest="45"
                            Command="{Binding GoToMenuCommand}"
                            Margin="0,20,0,0"/>
                </VerticalStackLayout>
            </CollectionView.EmptyView>
        </CollectionView>

        <!-- Итоговая сумма и кнопка оформления -->
        <Frame Grid.Row="1" 
               BackgroundColor="White" 
               CornerRadius="12" 
               Padding="15"
               HasShadow="True"
               BorderColor="#E0E0E0"
               Margin="0,10,0,0">

            <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="*,Auto">

                <Label Grid.Row="0" Grid.Column="0"
                       Text="Итого к оплате:" 
                       FontSize="16"
                       TextColor="#333"
                       VerticalOptions="Center"/>

                <Label Grid.Row="0" Grid.Column="1"
                       FontSize="22" 
                       FontAttributes="Bold"
                       TextColor="#D32F2F"
                       HorizontalOptions="End"
                       VerticalOptions="Center">
                    <Label.FormattedText>
                        <FormattedString>
                            <Span Text="{Binding TotalAmount, StringFormat='{0:N0}'}"/>
                            <Span Text=" ₽"/>
                        </FormattedString>
                    </Label.FormattedText>
                </Label>

                <Button Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                        Text="Оформить заказ"
                        BackgroundColor="#4CAF50"
                        TextColor="White"
                        FontAttributes="Bold"
                        FontSize="16"
                        CornerRadius="12"
                        HeightRequest="50"
                        Command="{Binding CheckoutCommand}"
                        IsEnabled="{Binding CanCheckout}"
                        Margin="0,10,0,0"/>
            </Grid>
        </Frame>
    </Grid>
</ContentPage>